# SMTP Configuration (Gmail, Mailtrap, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Mailgun Configuration (Optional fallback for HTTP API)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain

# LinkedIn Scraping Credentials (Optional - Mock data is used as a fallback if not provided)
LINKEDIN_USERNAME=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# External API for Email Verification & Search
HUNTER_API_KEY=your_hunter_api_key

# Email Tracking Configuration
TRACKING_SERVER_URL=http://localhost:5000
